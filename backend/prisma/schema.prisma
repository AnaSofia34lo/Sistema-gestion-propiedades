generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Property {
  id        Int      @id @default(autoincrement())
  title     String
  price     Float
  location  String
  available Boolean  @default(true)
  createdAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  password  String
  createdAt DateTime @default(now())
}
